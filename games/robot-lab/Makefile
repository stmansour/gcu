# ─────────────────────────────────────────────────────────────────────────────
# games/robot-lab/ — Robot Lab game
#
# Assets in assets/images/ are hand-crafted (SWIRL-E portraits, blueprints,
# circuit board photos). They are not generated by the prompt pipeline and
# are never cleaned.
# ─────────────────────────────────────────────────────────────────────────────

.PHONY: all clean package

all:
	@echo "robot-lab: nothing to build (assets are hand-crafted)"

clean:
	@echo "robot-lab: nothing to clean (assets are hand-crafted)"

package:
	@echo "robot-lab: package handled by root"
